HOST mr01 test01 test02 prod01 prod02 prod03 prod04
    CanonicalizeHostname always
    CanonicalDomains accomodata.net
    User root
    ForwardAgent yes
    RequestTTY force

HOST mr01 test01 test02
    PermitLocalCommand yes
    LocalCommand scp -r -q ~/.sshrc.d/.sshrc root@%h:/tmp/.sshrc_kenzo
    RemoteCommand (mv /tmp/.sshrc_kenzo /tmp/.sshrc_kenzo.file || true) && bash --rcfile /tmp/.sshrc_kenzo.file

HOST *.accomodata.net
    User root
    ForwardAgent yes


HOST *.2mprove.net
    User root
    ForwardAgent yes

HOST github.com
    HostName github.com
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

HOST github-personal
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_rsa

Host vtg
  HostkeyAlias vtg.accomodata.net
  user accomodata
  Port 22
  ProxyCommand ssh jump@jumphost.accomodata.net -W %h:%p
